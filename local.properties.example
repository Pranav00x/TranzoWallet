# Tranzo Wallet - Local Properties
# Copy this file to local.properties and replace placeholder values with your actual API keys.
# IMPORTANT: Never commit local.properties to version control.

# Android SDK location (auto-generated by Android Studio, update to match your system)
# sdk.dir=/Users/username/Library/Android/sdk

# Etherscan API key - get one at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinGecko API key - get one at https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here
